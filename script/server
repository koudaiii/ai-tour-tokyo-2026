#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "${ROOT_DIR}"

usage() {
  cat <<'EOF'
Usage: script/server [gunicorn options...]

Start the web application with gunicorn.
This script uses `exec ... run gunicorn` so signals are handled by gunicorn directly.
EOF
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

log() {
  echo "[server] $*"
}

load_env_file() {
  local env_file="${ROOT_DIR}/.env"
  if [[ -f "${env_file}" ]]; then
    log "Loading environment from ${env_file}"
    set -a
    # shellcheck disable=SC1090
    source "${env_file}"
    set +a
  fi
}

check_db_connection() {
  if ! command -v psql >/dev/null 2>&1; then
    echo "Error: 'psql' is required for DB connection precheck." >&2
    exit 1
  fi

  local output
  local database_url="${ISUCONP_DATABASE_URL:-postgresql://isuconp:isuconp@127.0.0.1:5432/isuconp}"
  local -a cmd=(psql "${database_url}" -v ON_ERROR_STOP=1 -Atqc "SELECT 1;")

  log "Checking PostgreSQL connection before app start"
  output="$("${cmd[@]}" 2>&1)" || {
    echo "Error: PostgreSQL connection precheck failed: ${output}" >&2
    exit 1
  }
}

load_env_file

UV_BIN=""
if command -v uv >/dev/null 2>&1; then
  UV_BIN="uv"
elif [[ -x .venv/bin/uv ]]; then
  UV_BIN=".venv/bin/uv"
else
  echo "Error: 'uv' is required but not installed (or .venv/bin/uv missing)." >&2
  exit 1
fi

if [[ ! -x .venv/bin/gunicorn ]]; then
  log ".venv/bin/gunicorn not found. Running ${UV_BIN} sync"
  "${UV_BIN}" sync
fi

if [[ ! -x .venv/bin/gunicorn ]]; then
  echo "Error: failed to prepare .venv/bin/gunicorn. Check uv sync output." >&2
  exit 1
fi

# macOS + gunicorn worker fork() + Objective-C runtime issue workaround.
# `exec` simplifies signal handling, but does not avoid this fork-time crash.
# Allow users to override by setting OBJC_DISABLE_INITIALIZE_FORK_SAFETY explicitly.
if [[ "$(uname -s)" == "Darwin" && -z "${OBJC_DISABLE_INITIALIZE_FORK_SAFETY:-}" ]]; then
  export OBJC_DISABLE_INITIALIZE_FORK_SAFETY=YES
  log "Set OBJC_DISABLE_INITIALIZE_FORK_SAFETY=YES for macOS gunicorn compatibility"
fi

GUNICORN_BIND="${ISUCONP_SERVER_BIND:-0.0.0.0:8080}"
GUNICORN_APP="${ISUCONP_SERVER_APP:-app:app}"

check_db_connection
log "Starting gunicorn ${GUNICORN_APP} on ${GUNICORN_BIND}"
exec "${UV_BIN}" run gunicorn \
  "${GUNICORN_APP}" \
  -b "${GUNICORN_BIND}" \
  --log-file - \
  --access-logfile - \
  "$@"
