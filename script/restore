#!/usr/bin/env bash
set -euo pipefail

DUMP_PATH="${DUMP_PATH:-/docker-entrypoint-initdb.d/isuconp_data.dump}"
ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
FIX_SEQUENCES_SQL="${ROOT_DIR}/sql/bootstrap_fix_sequences.sql"
RESTORE_COMMON_OPTS=(
  --clean
  --if-exists
  --no-owner
  --no-privileges
)

load_env_file() {
  local env_file="${ROOT_DIR}/.env"
  if [[ -f "${env_file}" ]]; then
    echo "[restore] loading environment from ${env_file}"
    set -a
    # shellcheck disable=SC1090
    source "${env_file}"
    set +a
  fi
}

run_fix_sequences() {
  if [[ ! -f "${FIX_SEQUENCES_SQL}" ]]; then
    echo "[restore] warning: sequence-fix SQL not found: ${FIX_SEQUENCES_SQL}" >&2
    return 0
  fi

  if [[ -n "${POSTGRES_USER:-}" && -n "${POSTGRES_DB:-}" ]]; then
    psql -v ON_ERROR_STOP=1 -U "${POSTGRES_USER}" -d "${POSTGRES_DB}" -f "${FIX_SEQUENCES_SQL}" >/dev/null
    return 0
  fi

  psql "${DATABASE_URL}" -v ON_ERROR_STOP=1 -f "${FIX_SEQUENCES_SQL}" >/dev/null
}

resolve_pg_restore_bin() {
  local best_bin=""
  local best_major=0
  local candidate

  for candidate in /usr/lib/postgresql/*/bin/pg_restore; do
    [[ -x "${candidate}" ]] || continue
    local candidate_major
    candidate_major="$(echo "${candidate}" | awk -F'/' '{print $(NF-2)}')"
    if [[ "${candidate_major}" =~ ^[0-9]+$ ]] && (( candidate_major > best_major )); then
      best_major="${candidate_major}"
      best_bin="${candidate}"
    fi
  done

  if [[ -z "${best_bin}" ]] && command -v pg_restore >/dev/null 2>&1; then
    best_bin="$(command -v pg_restore)"
  fi

  if [[ -z "${best_bin}" ]]; then
    echo "Error: 'pg_restore' is required but not installed." >&2
    exit 1
  fi
  echo "${best_bin}"
}

if [[ ! -f "${DUMP_PATH}" ]]; then
  echo "[restore] missing dump file: ${DUMP_PATH}" >&2
  echo "[restore] run 'make init' first or set DUMP_PATH" >&2
  exit 1
fi

load_env_file

PG_RESTORE_BIN="$(resolve_pg_restore_bin)"
DATABASE_URL="${ISUCONP_DATABASE_URL:-postgresql://isuconp:isuconp@127.0.0.1:5432/isuconp}"

if [[ -n "${POSTGRES_USER:-}" && -n "${POSTGRES_DB:-}" ]]; then
  echo "[restore] restoring ${DUMP_PATH} into ${POSTGRES_DB} (docker-entrypoint mode)"
  if ! "${PG_RESTORE_BIN}" \
    "${RESTORE_COMMON_OPTS[@]}" \
    -U "${POSTGRES_USER}" \
    -d "${POSTGRES_DB}" \
    "${DUMP_PATH}"; then
    echo "[restore] restore failed using ${PG_RESTORE_BIN}" >&2
    echo "[restore] If you see 'unsupported version ... in file header', install newer PostgreSQL client tools." >&2
    exit 1
  fi
  run_fix_sequences
  exit 0
fi

echo "[restore] restoring ${DUMP_PATH} using ISUCONP_DATABASE_URL"
if ! "${PG_RESTORE_BIN}" \
  "${RESTORE_COMMON_OPTS[@]}" \
  -d "${DATABASE_URL}" \
  "${DUMP_PATH}"; then
  echo "[restore] restore failed using ${PG_RESTORE_BIN}" >&2
  echo "[restore] If you see 'unsupported version ... in file header', install newer PostgreSQL client tools." >&2
  exit 1
fi

run_fix_sequences
