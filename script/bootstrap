#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

WITH_COMPOSE=0
SKIP_DB_CHECK=0

usage() {
  cat <<'EOF'
Usage: script/bootstrap [options]

Prepare local development environment for private-isu.

Options:
  --with-compose   Run `docker compose up -d --build`
  --skip-db-check  Skip PostgreSQL schema/permission checks
  -h, --help       Show this help
Environment:
  ISUCONP_DATABASE_URL  PostgreSQL connection URL (takes precedence over ISUCONP_DB_*)
EOF
}

require_cmd() {
  local cmd="$1"
  if ! command -v "${cmd}" >/dev/null 2>&1; then
    echo "Error: '${cmd}' is required but not installed." >&2
    exit 1
  fi
}

log() {
  echo "[bootstrap] $*"
}

error_exit() {
  echo "Error: $*" >&2
  exit 1
}

DB_CHECK_HOST=""
LAST_DB_ERROR=""
DEFAULTED_DB_HOST=0

run_sql() {
  local sql="$1"
  run_sql_file /dev/stdin <<<"${sql}"
}

run_sql_file() {
  local file="$1"
  shift
  local -a cmd
  if [[ -n "${ISUCONP_DATABASE_URL:-}" ]]; then
    cmd=(
      psql
      "${ISUCONP_DATABASE_URL}"
      -v ON_ERROR_STOP=1
      -Atqf "${file}"
    )
    while [[ $# -gt 0 ]]; do
      cmd+=(-v "$1")
      shift
    done
    "${cmd[@]}"
  else
    cmd=(psql)
    if [[ -n "${DB_CHECK_HOST}" ]]; then
      cmd+=(-h "${DB_CHECK_HOST}")
    fi
    cmd+=(
      -p "${ISUCONP_DB_PORT}"
      -U "${ISUCONP_DB_USER}"
      -d "${ISUCONP_DB_NAME}"
      -v ON_ERROR_STOP=1
      -Atqf "${file}"
    )
    while [[ $# -gt 0 ]]; do
      cmd+=(-v "$1")
      shift
    done

    if [[ -n "${ISUCONP_DB_PASSWORD:-}" ]]; then
      PGPASSWORD="${ISUCONP_DB_PASSWORD}" "${cmd[@]}"
    else
      "${cmd[@]}"
    fi
  fi
}

wait_for_db() {
  local retry=30
  while (( retry > 0 )); do
    if run_sql "SELECT 1;" >/dev/null 2>&1; then
      return 0
    fi
    sleep 1
    retry=$((retry - 1))
  done
  return 1
}

probe_db_connection() {
  local -a hosts=()
  local host
  local output

  if [[ -n "${ISUCONP_DATABASE_URL:-}" ]]; then
    DB_CHECK_HOST=""
    if output="$(run_sql "SELECT 1;" 2>&1)"; then
      LAST_DB_ERROR=""
      return 0
    fi
    LAST_DB_ERROR="${output}"
    return 1
  fi

  if [[ -n "${ISUCONP_DB_HOST:-}" && "${DEFAULTED_DB_HOST}" -eq 0 ]]; then
    hosts=("${ISUCONP_DB_HOST}")
  else
    hosts=("localhost" "127.0.0.1" "")
  fi

  for host in "${hosts[@]}"; do
    DB_CHECK_HOST="${host}"
    if output="$(run_sql "SELECT 1;" 2>&1)"; then
      LAST_DB_ERROR=""
      if [[ -n "${host}" ]]; then
        export ISUCONP_DB_HOST="${host}"
      fi
      return 0
    fi
    LAST_DB_ERROR="${output}"
  done
  return 1
}

run_admin_sql() {
  local db="$1"
  local sql="$2"
  run_admin_sql_file "${db}" /dev/stdin <<<"${sql}"
}

run_admin_sql_file() {
  local db="$1"
  local file="$2"
  shift 2
  local -a cmd=(psql -p "${ISUCONP_DB_PORT}" -d "${db}" -v ON_ERROR_STOP=1 -Atqf "${file}")
  if [[ -n "${DB_CHECK_HOST}" ]]; then
    cmd=(psql -h "${DB_CHECK_HOST}" -p "${ISUCONP_DB_PORT}" -d "${db}" -v ON_ERROR_STOP=1 -Atqf "${file}")
  fi
  while [[ $# -gt 0 ]]; do
    cmd+=(-v "$1")
    shift
  done
  "${cmd[@]}"
}

try_fix_local_role_and_db() {
  local db_exists

  if ! run_admin_sql "postgres" "SELECT 1;" >/dev/null 2>&1; then
    return 1
  fi

  log "Attempting to create missing role/database on local PostgreSQL"
  run_admin_sql_file "postgres" "${ROOT_DIR}/sql/bootstrap_create_role.sql"

  db_exists="$(run_admin_sql_file "postgres" "${ROOT_DIR}/sql/bootstrap_check_database_exists.sql" || true)"
  if [[ "${db_exists}" != "1" ]]; then
    run_admin_sql_file "postgres" "${ROOT_DIR}/sql/bootstrap_create_database.sql"
  fi

  run_admin_sql_file "postgres" "${ROOT_DIR}/sql/bootstrap_grant_connect_database.sql" >/dev/null 2>&1 || true
  return 0
}

try_fix_local_privileges() {
  if ! run_admin_sql "${ISUCONP_DB_NAME}" "SELECT 1;" >/dev/null 2>&1; then
    return 1
  fi

  log "Attempting to grant missing table/sequence privileges on local PostgreSQL"
  run_admin_sql_file "${ISUCONP_DB_NAME}" "${ROOT_DIR}/sql/bootstrap_grant_local_privileges.sql"
  return 0
}

try_fix_local_schema() {
  log "Attempting to load schema from sql/bootstrap_create_table.sql"
  if run_sql_file "${ROOT_DIR}/sql/bootstrap_create_table.sql" >/dev/null 2>&1; then
    return 0
  fi
  return 1
}

check_db_state() {
  local missing_tables=()
  local missing_table_privs=()
  local missing_seq_privs=()
  local table
  local priv
  local has_priv
  local seq_list

  if [[ -n "${ISUCONP_DATABASE_URL:-}" ]]; then
    log "Checking PostgreSQL connection via ISUCONP_DATABASE_URL"
  elif [[ -n "${ISUCONP_DB_HOST:-}" ]]; then
    log "Checking PostgreSQL connection: ${ISUCONP_DB_USER}@${ISUCONP_DB_HOST}:${ISUCONP_DB_PORT}/${ISUCONP_DB_NAME}"
  else
    log "Checking PostgreSQL connection: ${ISUCONP_DB_USER}@{127.0.0.1|localhost|socket}:${ISUCONP_DB_PORT}/${ISUCONP_DB_NAME}"
  fi

  if ! probe_db_connection; then
    local missing_role
    missing_role="$(printf '%s' "${LAST_DB_ERROR}" | sed -n 's/.*role "\([^"]*\)" does not exist.*/\1/p' | head -n1)"

    if [[ "${LAST_DB_ERROR}" == *"invalid URI"* || "${LAST_DB_ERROR}" == *"could not translate host name"* ]]; then
      error_exit "Invalid ISUCONP_DATABASE_URL or unreachable host. Details: ${LAST_DB_ERROR}"
    fi
    if [[ -n "${missing_role}" ]]; then
      if [[ -z "${ISUCONP_DATABASE_URL}" && ( "${DB_CHECK_HOST}" == "localhost" || "${DB_CHECK_HOST}" == "127.0.0.1" || -z "${DB_CHECK_HOST}" ) ]]; then
        if try_fix_local_role_and_db && probe_db_connection; then
          log "Created missing role/database and reconnected successfully"
        else
          error_exit "PostgreSQL role '${missing_role}' does not exist and automatic local fix failed. Run manually: psql -d postgres -c \"CREATE ROLE ${missing_role} LOGIN PASSWORD '...';\""
        fi
      else
        error_exit "PostgreSQL role '${missing_role}' does not exist. Create it first, for example: psql -d postgres -c \"CREATE ROLE ${missing_role} LOGIN PASSWORD '...';\""
      fi
    fi
    if ! probe_db_connection; then
      error_exit "Cannot connect to PostgreSQL with current ISUCONP_DB_* settings. Details: ${LAST_DB_ERROR}"
    fi
  fi

  for table in users posts comments; do
    if [[ "$(run_sql_file "${ROOT_DIR}/sql/bootstrap_check_table_exists.sql" "table_name=${table}")" != "t" ]]; then
      missing_tables+=("${table}")
    fi
  done

  for table in users posts comments; do
    if [[ "$(run_sql_file "${ROOT_DIR}/sql/bootstrap_check_table_exists.sql" "table_name=${table}")" != "t" ]]; then
      continue
    fi
    for priv in SELECT INSERT UPDATE DELETE; do
      has_priv="$(run_sql_file "${ROOT_DIR}/sql/bootstrap_check_table_privilege.sql" "table_name=${table}" "privilege_name=${priv}")"
      if [[ "${has_priv}" != "t" ]]; then
        missing_table_privs+=("${table}:${priv}")
      fi
    done
  done

  seq_list="$(run_sql_file "${ROOT_DIR}/sql/bootstrap_list_public_sequences.sql")"
  if [[ -n "${seq_list}" ]]; then
    while IFS= read -r seq; do
      [[ -z "${seq}" ]] && continue
      has_priv="$(run_sql_file "${ROOT_DIR}/sql/bootstrap_check_sequence_usage_privilege.sql" "sequence_name=${seq}")"
      if [[ "${has_priv}" != "t" ]]; then
        missing_seq_privs+=("${seq}:USAGE")
      fi
    done <<< "${seq_list}"
  fi

  if (( ${#missing_tables[@]} > 0 )); then
    if [[ -z "${ISUCONP_DATABASE_URL}" && ( "${DB_CHECK_HOST}" == "localhost" || "${DB_CHECK_HOST}" == "127.0.0.1" || -z "${DB_CHECK_HOST}" ) ]]; then
      if try_fix_local_schema; then
        missing_tables=()
        for table in users posts comments; do
          if [[ "$(run_sql_file "${ROOT_DIR}/sql/bootstrap_check_table_exists.sql" "table_name=${table}")" != "t" ]]; then
            missing_tables+=("${table}")
          fi
        done
      fi
    fi

    if (( ${#missing_tables[@]} > 0 )); then
      error_exit "Missing tables: ${missing_tables[*]}. Load schema with: psql -U ${ISUCONP_DB_USER} -d ${ISUCONP_DB_NAME} -f sql/bootstrap_create_table.sql then restore dump with: pg_restore -U ${ISUCONP_DB_USER} -d ${ISUCONP_DB_NAME} sql/isuconp_data.dump"
    fi
  fi

  if (( ${#missing_table_privs[@]} > 0 )) || (( ${#missing_seq_privs[@]} > 0 )); then
    if [[ -z "${ISUCONP_DATABASE_URL}" && ( "${DB_CHECK_HOST}" == "localhost" || "${DB_CHECK_HOST}" == "127.0.0.1" || -z "${DB_CHECK_HOST}" ) ]]; then
      if try_fix_local_privileges; then
        # Re-check once after automatic grant.
        missing_table_privs=()
        missing_seq_privs=()

        for table in users posts comments; do
          if [[ "$(run_sql_file "${ROOT_DIR}/sql/bootstrap_check_table_exists.sql" "table_name=${table}")" != "t" ]]; then
            continue
          fi
          for priv in SELECT INSERT UPDATE DELETE; do
            has_priv="$(run_sql_file "${ROOT_DIR}/sql/bootstrap_check_table_privilege.sql" "table_name=${table}" "privilege_name=${priv}")"
            if [[ "${has_priv}" != "t" ]]; then
              missing_table_privs+=("${table}:${priv}")
            fi
          done
        done

        seq_list="$(run_sql_file "${ROOT_DIR}/sql/bootstrap_list_public_sequences.sql")"
        if [[ -n "${seq_list}" ]]; then
          while IFS= read -r seq; do
            [[ -z "${seq}" ]] && continue
            has_priv="$(run_sql_file "${ROOT_DIR}/sql/bootstrap_check_sequence_usage_privilege.sql" "sequence_name=${seq}")"
            if [[ "${has_priv}" != "t" ]]; then
              missing_seq_privs+=("${seq}:USAGE")
            fi
          done <<< "${seq_list}"
        fi

        if (( ${#missing_table_privs[@]} > 0 )) || (( ${#missing_seq_privs[@]} > 0 )); then
          error_exit "Insufficient DB privileges. Missing table privileges: ${missing_table_privs[*]:-(none)} Missing sequence privileges: ${missing_seq_privs[*]:-(none)}. Grant example: GRANT SELECT, INSERT, UPDATE, DELETE ON ALL TABLES IN SCHEMA public TO ${ISUCONP_DB_USER}; GRANT USAGE, SELECT ON ALL SEQUENCES IN SCHEMA public TO ${ISUCONP_DB_USER};"
        fi
      else
        error_exit "Insufficient DB privileges and automatic local grant failed. Missing table privileges: ${missing_table_privs[*]:-(none)} Missing sequence privileges: ${missing_seq_privs[*]:-(none)}."
      fi
    else
      error_exit "Insufficient DB privileges. Missing table privileges: ${missing_table_privs[*]:-(none)} Missing sequence privileges: ${missing_seq_privs[*]:-(none)}. Grant example: GRANT SELECT, INSERT, UPDATE, DELETE ON ALL TABLES IN SCHEMA public TO ${ISUCONP_DB_USER}; GRANT USAGE, SELECT ON ALL SEQUENCES IN SCHEMA public TO ${ISUCONP_DB_USER};"
    fi
  fi

  log "PostgreSQL schema and permissions look good"
}

for arg in "$@"; do
  case "${arg}" in
    --with-compose)
      WITH_COMPOSE=1
      ;;
    --skip-db-check)
      SKIP_DB_CHECK=1
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "Error: unknown option '${arg}'" >&2
      usage
      exit 1
      ;;
  esac
done

cd "${ROOT_DIR}"

export ISUCONP_DB_HOST="${ISUCONP_DB_HOST:-}"
export ISUCONP_DB_PORT="${ISUCONP_DB_PORT:-}"
export ISUCONP_DB_USER="${ISUCONP_DB_USER:-}"
export ISUCONP_DB_PASSWORD="${ISUCONP_DB_PASSWORD:-}"
export ISUCONP_DB_NAME="${ISUCONP_DB_NAME:-}"
export ISUCONP_MEMCACHED_ADDRESS="${ISUCONP_MEMCACHED_ADDRESS:-127.0.0.1:11211}"
export ISUCONP_DATABASE_URL="${ISUCONP_DATABASE_URL:-}"

if [[ -z "${ISUCONP_DATABASE_URL}" ]]; then
  FIXED_DB_USER="isuconp"
  FIXED_DB_PASSWORD="isuconp"
  FIXED_DB_NAME="isuconp"

  if [[ -z "${ISUCONP_DB_HOST}" ]]; then
    export ISUCONP_DB_HOST="localhost"
    DEFAULTED_DB_HOST=1
    log "ISUCONP_DB_HOST is not set. Using default: localhost"
  fi
  if [[ -z "${ISUCONP_DB_PORT}" ]]; then
    export ISUCONP_DB_PORT="5432"
    log "ISUCONP_DB_PORT is not set. Using default: 5432"
  fi
  if [[ -z "${ISUCONP_DB_USER}" ]]; then
    export ISUCONP_DB_USER="${FIXED_DB_USER}"
    log "ISUCONP_DB_USER is not set. Using fixed value: ${FIXED_DB_USER}"
  elif [[ "${ISUCONP_DB_USER}" != "${FIXED_DB_USER}" ]]; then
    log "ISUCONP_DB_USER='${ISUCONP_DB_USER}' is overridden to fixed value: ${FIXED_DB_USER}"
    export ISUCONP_DB_USER="${FIXED_DB_USER}"
  fi
  if [[ -z "${ISUCONP_DB_PASSWORD}" ]]; then
    export ISUCONP_DB_PASSWORD="${FIXED_DB_PASSWORD}"
    log "ISUCONP_DB_PASSWORD is not set. Using fixed value: ${FIXED_DB_PASSWORD}"
  elif [[ "${ISUCONP_DB_PASSWORD}" != "${FIXED_DB_PASSWORD}" ]]; then
    log "ISUCONP_DB_PASSWORD is overridden to fixed value for bootstrap checks"
    export ISUCONP_DB_PASSWORD="${FIXED_DB_PASSWORD}"
  fi
  if [[ -z "${ISUCONP_DB_NAME}" ]]; then
    export ISUCONP_DB_NAME="${FIXED_DB_NAME}"
    log "ISUCONP_DB_NAME is not set. Using fixed value: ${FIXED_DB_NAME}"
  elif [[ "${ISUCONP_DB_NAME}" != "${FIXED_DB_NAME}" ]]; then
    log "ISUCONP_DB_NAME='${ISUCONP_DB_NAME}' is overridden to fixed value: ${FIXED_DB_NAME}"
    export ISUCONP_DB_NAME="${FIXED_DB_NAME}"
  fi
fi

require_cmd make
require_cmd curl
require_cmd python3
require_cmd bunzip2
require_cmd unzip

require_cmd uv
if [[ "${SKIP_DB_CHECK}" -eq 0 ]]; then
  require_cmd psql
fi

if [[ "${WITH_COMPOSE}" -eq 1 ]]; then
  require_cmd docker
  if ! docker compose version >/dev/null 2>&1; then
    echo "Error: docker compose plugin is required." >&2
    exit 1
  fi
fi

log "Running uv sync"
uv sync

if [[ "${WITH_COMPOSE}" -eq 1 ]]; then
  if [[ -z "${ISUCONP_DATABASE_URL}" && -z "${ISUCONP_DB_HOST}" ]]; then
    export ISUCONP_DB_HOST="127.0.0.1"
  fi
  log "Starting docker compose services"
  docker compose up -d --build
else
  log "Skipping docker compose startup (use --with-compose to run containers)"
fi

if [[ "${SKIP_DB_CHECK}" -eq 0 ]]; then
  if [[ "${WITH_COMPOSE}" -eq 1 ]]; then
    log "Waiting for PostgreSQL to become ready"
    if ! wait_for_db; then
      error_exit "PostgreSQL is not ready after docker compose start"
    fi
  fi
  check_db_state
else
  log "Skipping PostgreSQL checks (use default behavior to validate schema and permissions)"
fi

cat <<'EOF'

Bootstrap completed.

Helpful commands:
  - Open: http://localhost:8080
  - Start server: script/server
  - Stop server: Ctrl+C in the terminal running script/server
EOF
