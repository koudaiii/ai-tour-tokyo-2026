#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
NOW_YYYYMMDDHHMM="$(date +%Y%m%d%H%M)"
TEMPLATE_FILE="${ROOT_DIR}/infra/main.bicep"
TAGS_JSON='{"CostControl":"ignore","SecurityControl":"ignore","GitHub Repository":"koudaiii/ai-tour-tokyo-2026"}'
ENV_FILE="${ROOT_DIR}/.env"
WORKLOAD_CODE="pisu"
DEPLOYMENT_ENVIRONMENT="sandbox"

usage() {
  cat <<'EOF'
Usage: script/deploy-infra [options]

Deploy infrastructure defined in infra/main.bicep.

Options:
  --location LOCATION         Azure location for subscription deployment (default: japaneast)
  --deployment-name NAME      Deployment name (default: private-isu-infra-YYYYMMDDHHmm)
  --date-suffix VALUE         nowYyyymmddHhmm parameter value (default: YYYYMMDDHHmm)
  --storage-account NAME      storageAccountName parameter value
  --container-name NAME       containerName parameter value (default: images)
  --postgres-server NAME      postgresServerName parameter value
  --postgres-admin-user NAME  postgresAdminUser parameter value (default: isuconp)
  --postgres-password VALUE   postgresAdminPassword parameter value (default: auto-generated)
  --postgres-db-name NAME     postgresDatabaseName parameter value (default: isuconp)
  --postgres-entra-admin-object-id VALUE
                              postgresEntraAdminObjectId parameter value (default: signed-in principal object id)
  --postgres-entra-admin-name VALUE
                              postgresEntraAdminPrincipalName parameter value (default: signed-in principal name)
  --postgres-entra-admin-type VALUE
                              postgresEntraAdminPrincipalType parameter value (default: User or ServicePrincipal)
  --postgres-version VALUE    postgresVersion parameter value (default: 18; only 18 is supported)
  --postgres-tier VALUE       postgresTier parameter value (default: Burstable)
  --postgres-sku NAME         postgresSkuName parameter value (default: Standard_B1ms)
  --postgres-storage-gb NUM   postgresStorageSizeGB parameter value (default: 32)
  --aca-env-name NAME         containerAppsEnvironmentName parameter value
  --aca-app-name NAME         containerAppName parameter value
  --app-image IMAGE           appContainerImage parameter value (default: docker.io/koudaiii/ai-tour-tokyo-2026:latest)
  --memcached-image IMAGE     memcachedContainerImage parameter value (default: docker.io/library/memcached:1.6)
  --seed-func-app NAME        seedFunctionAppName parameter value
  --seed-func-plan NAME       seedFunctionAppServicePlanName parameter value
  --seed-func-storage NAME    seedFunctionsStorageAccountName parameter value
  --skip-storage-role-grant   Skip running script/grant-storage-role after deploy
  --skip-postgres-mi-grant    Deprecated (script/grant-postgres-mi-role is not executed)
  --dry-run                   Run what-if instead of create
  -h, --help                  Show this help
EOF
}

require_cmd() {
  local cmd="$1"
  if ! command -v "${cmd}" >/dev/null 2>&1; then
    echo "Error: '${cmd}' is required but not installed." >&2
    exit 1
  fi
}

log() {
  echo "[deploy-infra] $*"
}

log_resolved_parameters() {
  log "Resolved parameters:"
  log "LOCATION=${LOCATION}"
  log "REGION_CODE=${REGION_CODE}"
  log "WORKLOAD_CODE=${WORKLOAD_CODE}"
  log "DEPLOYMENT_ENVIRONMENT=${DEPLOYMENT_ENVIRONMENT}"
  log "DEPLOYMENT_NAME=${DEPLOYMENT_NAME}"
  log "DATE_SUFFIX=${DATE_SUFFIX}"
  log "STORAGE_ACCOUNT_NAME=${STORAGE_ACCOUNT_NAME}"
  log "CONTAINER_NAME=${CONTAINER_NAME}"
  log "POSTGRES_SERVER_NAME=${POSTGRES_SERVER_NAME}"
  log "POSTGRES_ADMIN_USER=${POSTGRES_ADMIN_USER}"
  log "POSTGRES_DB_NAME=${POSTGRES_DB_NAME}"
  log "POSTGRES_ENTRA_ADMIN_OBJECT_ID=${POSTGRES_ENTRA_ADMIN_OBJECT_ID}"
  log "POSTGRES_ENTRA_ADMIN_NAME=${POSTGRES_ENTRA_ADMIN_NAME}"
  log "POSTGRES_ENTRA_ADMIN_TYPE=${POSTGRES_ENTRA_ADMIN_TYPE}"
  log "POSTGRES_VERSION=${POSTGRES_VERSION}"
  log "POSTGRES_TIER=${POSTGRES_TIER}"
  log "POSTGRES_SKU_NAME=${POSTGRES_SKU_NAME}"
  log "POSTGRES_STORAGE_GB=${POSTGRES_STORAGE_GB}"
  log "CONTAINER_APPS_ENVIRONMENT_NAME=${CONTAINER_APPS_ENVIRONMENT_NAME}"
  log "CONTAINER_APP_NAME=${CONTAINER_APP_NAME}"
  log "VIRTUAL_NETWORK_NAME=${VIRTUAL_NETWORK_NAME}"
  log "APP_CONTAINER_IMAGE=${APP_CONTAINER_IMAGE}"
  log "MEMCACHED_CONTAINER_IMAGE=${MEMCACHED_CONTAINER_IMAGE}"
  log "FUNCTION_APP_NAME=${FUNCTION_APP_NAME}"
  log "FUNCTION_APP_SERVICE_PLAN_NAME=${FUNCTION_APP_SERVICE_PLAN_NAME}"
  log "FUNCTIONS_STORAGE_ACCOUNT_NAME=${FUNCTIONS_STORAGE_ACCOUNT_NAME}"
  log "SEED_FUNCTION_APP_NAME=${SEED_FUNCTION_APP_NAME}"
  log "SEED_FUNCTION_APP_SERVICE_PLAN_NAME=${SEED_FUNCTION_APP_SERVICE_PLAN_NAME}"
  log "SEED_FUNCTIONS_STORAGE_ACCOUNT_NAME=${SEED_FUNCTIONS_STORAGE_ACCOUNT_NAME}"
  log "POSTGRES_ADMIN_PASSWORD=***"
  log "TAGS_JSON=${TAGS_JSON}"
}

print_application_env() {
  local account_url
  account_url="https://${STORAGE_ACCOUNT_NAME}.blob.core.windows.net/"
  local postgres_host database_url
  postgres_host="${POSTGRES_SERVER_NAME}.postgres.database.azure.com"
  database_url="postgresql://${POSTGRES_ADMIN_USER}:${POSTGRES_ADMIN_PASSWORD}@${postgres_host}:5432/${POSTGRES_DB_NAME}?sslmode=require"
  log "Application environment variables (KEY=VALUE):"
  echo "AZURE_STORAGE_ACCOUNT_URL=${account_url}"
  echo "AZURE_STORAGE_CONTAINER_NAME=${CONTAINER_NAME}"
  echo "ISUCONP_DATABASE_URL=${database_url}"
  echo "ISUCONP_DB_HOST=${postgres_host}"
  echo "ISUCONP_DB_NAME=${POSTGRES_DB_NAME}"
  echo "CONTAINER_APP_NAME=${CONTAINER_APP_NAME}"
  echo "# Container App: https://${CONTAINER_APP_NAME}.<generated-domain>"
}

print_apim_test_guide() {
  local apim_gateway_url
  apim_gateway_url="https://${APIM_NAME}.azure-api.net"

  cat <<EOF

===============================================================
  API Management - Test & Verification Guide
===============================================================

Gateway URL: ${apim_gateway_url}

# List timeline posts
curl -s ${apim_gateway_url}/api/posts | jq .

# Get a single post (id=1)
curl -s ${apim_gateway_url}/api/posts/1 | jq .

# List all users
curl -s ${apim_gateway_url}/api/users | jq .

# Get user profile
curl -s ${apim_gateway_url}/api/users/mary | jq .

# Get user's posts
curl -s ${apim_gateway_url}/api/users/mary/posts | jq .

# Health check (response time)
curl -s -o /dev/null -w 'HTTP %{http_code} in %{time_total}s\n' ${apim_gateway_url}/api/posts

# Verify OpenAPI spec is loaded (via Azure CLI)
az apim api show --resource-group "rg-${WORKLOAD_CODE}-${DEPLOYMENT_ENVIRONMENT}-${REGION_CODE}-${DATE_YYMMDDHHMM}" \\
  --service-name "${APIM_NAME}" --api-id private-isu-api -o table

===============================================================
EOF
}

print_mcp_config() {
  local func_hostname
  func_hostname="${FUNCTION_APP_NAME}.azurewebsites.net"

  cat <<EOF

===============================================================
  Remote MCP Server - Configuration
===============================================================

Function App: ${FUNCTION_APP_NAME}
MCP Endpoint: https://${func_hostname}/runtime/webhooks/mcp

# Deploy mcp-server code to Azure Functions:
cd mcp-server && func azure functionapp publish ${FUNCTION_APP_NAME}

# Claude Code MCP config (~/.claude/settings.json):
{
  "mcpServers": {
    "private-isu": {
      "type": "http",
      "url": "https://${func_hostname}/runtime/webhooks/mcp"
    }
  }
}

# VS Code MCP config (.vscode/mcp.json):
{
  "servers": {
    "private-isu": {
      "type": "http",
      "url": "https://${func_hostname}/runtime/webhooks/mcp"
    }
  }
}

# Available MCP tools:
#   browse_timeline   - Browse posts with keyword filter and pagination
#   explore_user      - User profile + stats + recent posts in one call
#   find_popular_posts - Posts ranked by engagement (comment count)
#   get_conversation  - Post + comment thread in readable format
#   compare_users     - Side-by-side user activity comparison
#   search_posts      - Keyword search across posts and comments

===============================================================
EOF
}

print_seed_config() {
  local seed_hostname rg_name seed_key_cmd
  seed_hostname="${SEED_FUNCTION_APP_NAME}.azurewebsites.net"
  rg_name="rg-${WORKLOAD_CODE}-${DEPLOYMENT_ENVIRONMENT}-${REGION_CODE}-${DATE_YYMMDDHHMM}"
  seed_key_cmd="az functionapp function keys list --resource-group ${rg_name} --name ${SEED_FUNCTION_APP_NAME} --function-name seed_now --query default -o tsv"

  cat <<EOF

===============================================================
  Seed Function - Manual Trigger
===============================================================

Seed Function App: ${SEED_FUNCTION_APP_NAME}
Seed Endpoint: https://${seed_hostname}/api/seed-now

# Deploy seed-functions code to Azure Functions:
cd seed-functions && func azure functionapp publish ${SEED_FUNCTION_APP_NAME} --python

# Get function key:
${seed_key_cmd}

# Trigger seed via script/seed (API mode):
export SEED_FUNCTION_KEY="\$( ${seed_key_cmd} )"
script/seed | jq .

# Or trigger directly:
curl -s -X POST "https://${seed_hostname}/api/seed-now" \
  -H "x-functions-key: \$( ${seed_key_cmd} )" \
  -H "Content-Type: application/json" \
  --data '{"post_count":100}' | jq .

===============================================================
EOF
}

write_application_env_file() {
  local account_url postgres_host database_url tmp_file
  account_url="https://${STORAGE_ACCOUNT_NAME}.blob.core.windows.net/"
  postgres_host="${POSTGRES_SERVER_NAME}.postgres.database.azure.com"
  database_url="postgresql://${POSTGRES_ADMIN_USER}:${POSTGRES_ADMIN_PASSWORD}@${postgres_host}:5432/${POSTGRES_DB_NAME}?sslmode=require"
  tmp_file="$(mktemp)"

  touch "${ENV_FILE}"
  grep -vE '^(AZURE_STORAGE_ACCOUNT_URL|AZURE_STORAGE_CONTAINER_NAME|ISUCONP_DATABASE_URL|ISUCONP_DB_HOST|ISUCONP_DB_NAME|CONTAINER_APP_NAME|ISUCONP_DB_PORT|ISUCONP_DB_USER|ISUCONP_DB_PASSWORD|APIM_NAME|APIM_GATEWAY_URL|FUNCTION_APP_NAME|FUNCTION_APP_MCP_ENDPOINT|SEED_FUNCTION_APP_NAME|SEED_FUNCTION_APP_ENDPOINT)=' "${ENV_FILE}" > "${tmp_file}" || true
  {
    cat "${tmp_file}"
    echo "AZURE_STORAGE_ACCOUNT_URL=${account_url}"
    echo "AZURE_STORAGE_CONTAINER_NAME=${CONTAINER_NAME}"
    echo "ISUCONP_DATABASE_URL=${database_url}"
    echo "ISUCONP_DB_HOST=${postgres_host}"
    echo "ISUCONP_DB_NAME=${POSTGRES_DB_NAME}"
    echo "CONTAINER_APP_NAME=${CONTAINER_APP_NAME}"
    echo "APIM_NAME=${APIM_NAME}"
    echo "APIM_GATEWAY_URL=https://${APIM_NAME}.azure-api.net"
    echo "FUNCTION_APP_NAME=${FUNCTION_APP_NAME}"
    echo "FUNCTION_APP_MCP_ENDPOINT=https://${FUNCTION_APP_NAME}.azurewebsites.net/runtime/webhooks/mcp"
    echo "SEED_FUNCTION_APP_NAME=${SEED_FUNCTION_APP_NAME}"
    echo "SEED_FUNCTION_APP_ENDPOINT=https://${SEED_FUNCTION_APP_NAME}.azurewebsites.net/api/seed-now"
  } > "${ENV_FILE}"
  rm -f "${tmp_file}"

  log "Updated ${ENV_FILE} with Azure storage and PostgreSQL environment variables"
}

run_az() {
  if [[ "${DRY_RUN}" -eq 1 ]]; then
    local first=1
    local arg
    for arg in az "$@"; do
      if [[ "${first}" -eq 1 ]]; then
        printf '%q' "${arg}"
        first=0
      else
        printf ' %q' "${arg}"
      fi
    done
    printf '\n'
    return 0
  fi
  az "$@"
}

ensure_azure_login() {
  if ! az account show --output none >/dev/null 2>&1; then
    echo "Error: Azure login required. Run 'az login' first." >&2
    exit 1
  fi
  local account
  account="$(az account show --query '{user:user.name,subscription:name}' -o tsv 2>/dev/null | tr '\t' ' ')"
  log "Azure login confirmed: ${account}"
}

generate_storage_account_name() {
  local suffix rand
  suffix="${DATE_YYMMDD}"
  rand="$(LC_ALL=C tr -dc 'a-z0-9' </dev/urandom | head -c 2)"
  echo "st${WORKLOAD_CODE}sbx${REGION_CODE}${suffix}${rand}" | cut -c1-24
}

generate_postgres_server_name() {
  local suffix rand
  suffix="${DATE_SUFFIX}"
  rand="$(LC_ALL=C tr -dc 'a-z0-9' </dev/urandom | head -c 4)"
  echo "pgfs-${WORKLOAD_CODE}-${DEPLOYMENT_ENVIRONMENT}-${REGION_CODE}-${suffix}-${rand}" | cut -c1-63
}

generate_container_apps_environment_name() {
  echo "acae-${WORKLOAD_CODE}-${DEPLOYMENT_ENVIRONMENT}-${REGION_CODE}-${DATE_YYMMDDHHMM}" | cut -c1-32
}

generate_container_app_name() {
  echo "aca-${WORKLOAD_CODE}-${DEPLOYMENT_ENVIRONMENT}-${REGION_CODE}-${DATE_YYMMDDHHMM}" | cut -c1-32
}

generate_virtual_network_name() {
  echo "vnet-${WORKLOAD_CODE}-${DEPLOYMENT_ENVIRONMENT}-${REGION_CODE}-${DATE_YYMMDDHHMM}" | cut -c1-64
}

generate_function_app_name() {
  echo "func-${WORKLOAD_CODE}-mcp-${DEPLOYMENT_ENVIRONMENT}-${REGION_CODE}-${DATE_YYMMDDHHMM}" | cut -c1-60
}

generate_function_app_service_plan_name() {
  echo "asp-${WORKLOAD_CODE}-mcp-${DEPLOYMENT_ENVIRONMENT}-${REGION_CODE}-${DATE_YYMMDDHHMM}" | cut -c1-40
}

generate_functions_storage_account_name() {
  local rand
  rand="$(LC_ALL=C tr -dc 'a-z0-9' </dev/urandom | head -c 2)"
  echo "stfn${WORKLOAD_CODE}${REGION_CODE}${DATE_YYMMDD:0:6}${rand}" | cut -c1-24
}

generate_seed_function_app_name() {
  echo "func-${WORKLOAD_CODE}-seed-${DEPLOYMENT_ENVIRONMENT}-${REGION_CODE}-${DATE_YYMMDDHHMM}" | cut -c1-60
}

generate_seed_function_app_service_plan_name() {
  echo "asp-${WORKLOAD_CODE}-seed-${DEPLOYMENT_ENVIRONMENT}-${REGION_CODE}-${DATE_YYMMDDHHMM}" | cut -c1-40
}

generate_seed_functions_storage_account_name() {
  local rand
  rand="$(LC_ALL=C tr -dc 'a-z0-9' </dev/urandom | head -c 2)"
  echo "stfs${WORKLOAD_CODE}${REGION_CODE}${DATE_YYMMDD:0:6}${rand}" | cut -c1-24
}

resolve_region_code() {
  case "${LOCATION}" in
    japaneast) REGION_CODE="jpe" ;;
    japanwest) REGION_CODE="jpw" ;;
    eastus) REGION_CODE="eus" ;;
    eastus2) REGION_CODE="eus2" ;;
    westus) REGION_CODE="wus" ;;
    westus2) REGION_CODE="wus2" ;;
    westus3) REGION_CODE="wus3" ;;
    centralus) REGION_CODE="cus" ;;
    northeurope) REGION_CODE="neu" ;;
    westeurope) REGION_CODE="weu" ;;
    southeastasia) REGION_CODE="sea" ;;
    *) REGION_CODE="$(echo "${LOCATION}" | tr -cd '[:alnum:]' | tr '[:upper:]' '[:lower:]' | cut -c1-6)" ;;
  esac
}

generate_postgres_password() {
  local upper lower digit special rest
  upper="$(LC_ALL=C tr -dc 'A-Z' </dev/urandom | head -c 1)"
  lower="$(LC_ALL=C tr -dc 'a-z' </dev/urandom | head -c 1)"
  digit="$(LC_ALL=C tr -dc '0-9' </dev/urandom | head -c 1)"
  special='!'
  rest="$(LC_ALL=C tr -dc 'A-Za-z0-9' </dev/urandom | head -c 20)"
  echo "${upper}${lower}${digit}${special}${rest}"
}

resolve_postgres_entra_admin_defaults() {
  if [[ -n "${POSTGRES_ENTRA_ADMIN_OBJECT_ID}" && -n "${POSTGRES_ENTRA_ADMIN_NAME}" ]]; then
    return 0
  fi

  local object_id=""
  local principal_name=""
  local principal_type=""

  object_id="$(az ad signed-in-user show --query id -o tsv 2>/dev/null || true)"
  principal_name="$(az ad signed-in-user show --query userPrincipalName -o tsv 2>/dev/null || true)"
  if [[ -n "${object_id}" && -n "${principal_name}" ]]; then
    principal_type="User"
  else
    principal_name="$(az account show --query user.name -o tsv)"
    object_id="$(az ad sp show --id "${principal_name}" --query id -o tsv 2>/dev/null || true)"
    principal_type="ServicePrincipal"
  fi

  if [[ -z "${object_id}" || -z "${principal_name}" ]]; then
    echo "Error: Failed to resolve default PostgreSQL Entra admin principal. Pass --postgres-entra-admin-object-id and --postgres-entra-admin-name explicitly." >&2
    exit 1
  fi

  if [[ -z "${POSTGRES_ENTRA_ADMIN_OBJECT_ID}" ]]; then
    POSTGRES_ENTRA_ADMIN_OBJECT_ID="${object_id}"
  fi
  if [[ -z "${POSTGRES_ENTRA_ADMIN_NAME}" ]]; then
    POSTGRES_ENTRA_ADMIN_NAME="${principal_name}"
  fi
  if [[ -z "${POSTGRES_ENTRA_ADMIN_TYPE}" ]]; then
    POSTGRES_ENTRA_ADMIN_TYPE="${principal_type}"
  fi
}

LOCATION="japaneast"
DATE_SUFFIX="${NOW_YYYYMMDDHHMM}"
DATE_YYMMDD="${DATE_SUFFIX:2:8}"
DATE_YYMMDDHHMM="${DATE_SUFFIX:2:10}"
REGION_CODE="jpe"
DEPLOYMENT_NAME="private-isu-infra-${NOW_YYYYMMDDHHMM}"
STORAGE_ACCOUNT_NAME=""
CONTAINER_NAME="images"
POSTGRES_SERVER_NAME=""
POSTGRES_ADMIN_USER="isuconp"
POSTGRES_ADMIN_PASSWORD=""
POSTGRES_DB_NAME="isuconp"
POSTGRES_ENTRA_ADMIN_OBJECT_ID=""
POSTGRES_ENTRA_ADMIN_NAME=""
POSTGRES_ENTRA_ADMIN_TYPE=""
POSTGRES_VERSION="18"
POSTGRES_TIER="Burstable"
POSTGRES_SKU_NAME="Standard_B1ms"
POSTGRES_STORAGE_GB="32"
CONTAINER_APPS_ENVIRONMENT_NAME=""
CONTAINER_APP_NAME=""
VIRTUAL_NETWORK_NAME=""
APP_CONTAINER_IMAGE="docker.io/koudaiii/ai-tour-tokyo-2026:latest"
MEMCACHED_CONTAINER_IMAGE="docker.io/library/memcached:1.6"
FUNCTION_APP_NAME=""
FUNCTION_APP_SERVICE_PLAN_NAME=""
FUNCTIONS_STORAGE_ACCOUNT_NAME=""
SEED_FUNCTION_APP_NAME=""
SEED_FUNCTION_APP_SERVICE_PLAN_NAME=""
SEED_FUNCTIONS_STORAGE_ACCOUNT_NAME=""
APIM_NAME=""
DRY_RUN=0
RUN_STORAGE_ROLE_GRANT=1
RUN_POSTGRES_MI_GRANT=1

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --location)
        LOCATION="${2:-}"
        shift 2
        ;;
      --deployment-name)
        DEPLOYMENT_NAME="${2:-}"
        shift 2
        ;;
      --date-suffix)
        DATE_SUFFIX="${2:-}"
        shift 2
        ;;
      --storage-account)
        STORAGE_ACCOUNT_NAME="${2:-}"
        shift 2
        ;;
      --container-name)
        CONTAINER_NAME="${2:-}"
        shift 2
        ;;
      --postgres-server)
        POSTGRES_SERVER_NAME="${2:-}"
        shift 2
        ;;
      --postgres-admin-user)
        POSTGRES_ADMIN_USER="${2:-}"
        shift 2
        ;;
      --postgres-password)
        POSTGRES_ADMIN_PASSWORD="${2:-}"
        shift 2
        ;;
      --postgres-db-name)
        POSTGRES_DB_NAME="${2:-}"
        shift 2
        ;;
      --postgres-entra-admin-object-id)
        POSTGRES_ENTRA_ADMIN_OBJECT_ID="${2:-}"
        shift 2
        ;;
      --postgres-entra-admin-name)
        POSTGRES_ENTRA_ADMIN_NAME="${2:-}"
        shift 2
        ;;
      --postgres-entra-admin-type)
        POSTGRES_ENTRA_ADMIN_TYPE="${2:-}"
        shift 2
        ;;
      --postgres-version)
        POSTGRES_VERSION="${2:-}"
        shift 2
        ;;
      --postgres-tier)
        POSTGRES_TIER="${2:-}"
        shift 2
        ;;
      --postgres-sku)
        POSTGRES_SKU_NAME="${2:-}"
        shift 2
        ;;
      --postgres-storage-gb)
        POSTGRES_STORAGE_GB="${2:-}"
        shift 2
        ;;
      --aca-env-name)
        CONTAINER_APPS_ENVIRONMENT_NAME="${2:-}"
        shift 2
        ;;
      --aca-app-name)
        CONTAINER_APP_NAME="${2:-}"
        shift 2
        ;;
      --app-image)
        APP_CONTAINER_IMAGE="${2:-}"
        shift 2
        ;;
      --memcached-image)
        MEMCACHED_CONTAINER_IMAGE="${2:-}"
        shift 2
        ;;
      --seed-func-app)
        SEED_FUNCTION_APP_NAME="${2:-}"
        shift 2
        ;;
      --seed-func-plan)
        SEED_FUNCTION_APP_SERVICE_PLAN_NAME="${2:-}"
        shift 2
        ;;
      --seed-func-storage)
        SEED_FUNCTIONS_STORAGE_ACCOUNT_NAME="${2:-}"
        shift 2
        ;;
      --skip-storage-role-grant)
        RUN_STORAGE_ROLE_GRANT=0
        shift
        ;;
      --skip-postgres-mi-grant)
        RUN_POSTGRES_MI_GRANT=0
        shift
        ;;
      --dry-run)
        DRY_RUN=1
        shift
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      *)
        echo "Error: unknown option '$1'" >&2
        usage
        exit 1
        ;;
    esac
  done
}

validate_inputs() {
  if [[ ! -f "${TEMPLATE_FILE}" ]]; then
    echo "Error: template file not found: ${TEMPLATE_FILE}" >&2
    exit 1
  fi
  if [[ ! "${DATE_SUFFIX}" =~ ^[0-9]{12}$ ]]; then
    echo "Error: --date-suffix must be 12 digits (YYYYMMDDHHmm)." >&2
    exit 1
  fi

  resolve_region_code
  DATE_YYMMDD="${DATE_SUFFIX:2:8}"
  DATE_YYMMDDHHMM="${DATE_SUFFIX:2:10}"

  if [[ -z "${STORAGE_ACCOUNT_NAME}" ]]; then
    STORAGE_ACCOUNT_NAME="$(generate_storage_account_name)"
  fi
  if [[ ! "${STORAGE_ACCOUNT_NAME}" =~ ^[a-z0-9]{3,24}$ ]]; then
    echo "Error: --storage-account must be 3-24 chars of lowercase letters and digits." >&2
    exit 1
  fi

  if [[ -z "${POSTGRES_SERVER_NAME}" ]]; then
    POSTGRES_SERVER_NAME="$(generate_postgres_server_name)"
  fi
  if [[ ! "${POSTGRES_SERVER_NAME}" =~ ^[a-z0-9-]{3,63}$ ]]; then
    echo "Error: --postgres-server must be 3-63 chars of lowercase letters, digits, and hyphens." >&2
    exit 1
  fi
  if [[ ! "${POSTGRES_SERVER_NAME}" =~ ^[a-z0-9].*[a-z0-9]$ ]]; then
    echo "Error: --postgres-server must start and end with lowercase letter or digit." >&2
    exit 1
  fi
  if [[ -z "${POSTGRES_ADMIN_PASSWORD}" ]]; then
    POSTGRES_ADMIN_PASSWORD="$(generate_postgres_password)"
  fi
  resolve_postgres_entra_admin_defaults
  if [[ -z "${CONTAINER_APPS_ENVIRONMENT_NAME}" ]]; then
    CONTAINER_APPS_ENVIRONMENT_NAME="$(generate_container_apps_environment_name)"
  fi
  if [[ -z "${CONTAINER_APP_NAME}" ]]; then
    CONTAINER_APP_NAME="$(generate_container_app_name)"
  fi
  if [[ -z "${VIRTUAL_NETWORK_NAME}" ]]; then
    VIRTUAL_NETWORK_NAME="$(generate_virtual_network_name)"
  fi
  if [[ ! "${POSTGRES_VERSION}" =~ ^18$ ]]; then
    echo "Error: --postgres-version must be 18." >&2
    exit 1
  fi
  if [[ ! "${POSTGRES_TIER}" =~ ^(Burstable|GeneralPurpose|MemoryOptimized)$ ]]; then
    echo "Error: --postgres-tier must be one of: Burstable, GeneralPurpose, MemoryOptimized." >&2
    exit 1
  fi
  if [[ ! "${POSTGRES_STORAGE_GB}" =~ ^[0-9]+$ ]]; then
    echo "Error: --postgres-storage-gb must be an integer." >&2
    exit 1
  fi
  if [[ ! "${POSTGRES_ENTRA_ADMIN_TYPE}" =~ ^(User|Group|ServicePrincipal)$ ]]; then
    echo "Error: --postgres-entra-admin-type must be one of: User, Group, ServicePrincipal." >&2
    exit 1
  fi

  if [[ -z "${FUNCTION_APP_NAME}" ]]; then
    FUNCTION_APP_NAME="$(generate_function_app_name)"
  fi
  if [[ -z "${FUNCTION_APP_SERVICE_PLAN_NAME}" ]]; then
    FUNCTION_APP_SERVICE_PLAN_NAME="$(generate_function_app_service_plan_name)"
  fi
  if [[ -z "${FUNCTIONS_STORAGE_ACCOUNT_NAME}" ]]; then
    FUNCTIONS_STORAGE_ACCOUNT_NAME="$(generate_functions_storage_account_name)"
  fi
  if [[ -z "${SEED_FUNCTION_APP_NAME}" ]]; then
    SEED_FUNCTION_APP_NAME="$(generate_seed_function_app_name)"
  fi
  if [[ -z "${SEED_FUNCTION_APP_SERVICE_PLAN_NAME}" ]]; then
    SEED_FUNCTION_APP_SERVICE_PLAN_NAME="$(generate_seed_function_app_service_plan_name)"
  fi
  if [[ -z "${SEED_FUNCTIONS_STORAGE_ACCOUNT_NAME}" ]]; then
    SEED_FUNCTIONS_STORAGE_ACCOUNT_NAME="$(generate_seed_functions_storage_account_name)"
  fi
  if [[ -z "${APIM_NAME}" ]]; then
    APIM_NAME="apim-${WORKLOAD_CODE}-${DEPLOYMENT_ENVIRONMENT}-${REGION_CODE}-${DATE_YYMMDDHHMM}"
  fi
}

main() {
  parse_args "$@"
  require_cmd az
  ensure_azure_login
  validate_inputs

  local -a deploy_cmd=(
    deployment sub create
    --name "${DEPLOYMENT_NAME}"
    --location "${LOCATION}"
    --template-file "${TEMPLATE_FILE}"
    --parameters
    "nowYyyymmddHhmm=${DATE_SUFFIX}"
    "workloadCode=${WORKLOAD_CODE}"
    "deploymentEnvironment=${DEPLOYMENT_ENVIRONMENT}"
    "regionCode=${REGION_CODE}"
    "storageAccountName=${STORAGE_ACCOUNT_NAME}"
    "containerName=${CONTAINER_NAME}"
    "postgresServerName=${POSTGRES_SERVER_NAME}"
    "postgresAdminUser=${POSTGRES_ADMIN_USER}"
    "postgresAdminPassword=${POSTGRES_ADMIN_PASSWORD}"
    "postgresDatabaseName=${POSTGRES_DB_NAME}"
    "postgresEntraAdminObjectId=${POSTGRES_ENTRA_ADMIN_OBJECT_ID}"
    "postgresEntraAdminPrincipalName=${POSTGRES_ENTRA_ADMIN_NAME}"
    "postgresEntraAdminPrincipalType=${POSTGRES_ENTRA_ADMIN_TYPE}"
    "postgresVersion=${POSTGRES_VERSION}"
    "postgresTier=${POSTGRES_TIER}"
    "postgresSkuName=${POSTGRES_SKU_NAME}"
    "postgresStorageSizeGB=${POSTGRES_STORAGE_GB}"
    "containerAppsEnvironmentName=${CONTAINER_APPS_ENVIRONMENT_NAME}"
    "containerAppName=${CONTAINER_APP_NAME}"
    "virtualNetworkName=${VIRTUAL_NETWORK_NAME}"
    "appContainerImage=${APP_CONTAINER_IMAGE}"
    "memcachedContainerImage=${MEMCACHED_CONTAINER_IMAGE}"
    "functionAppName=${FUNCTION_APP_NAME}"
    "functionAppServicePlanName=${FUNCTION_APP_SERVICE_PLAN_NAME}"
    "functionsStorageAccountName=${FUNCTIONS_STORAGE_ACCOUNT_NAME}"
    "seedFunctionAppName=${SEED_FUNCTION_APP_NAME}"
    "seedFunctionAppServicePlanName=${SEED_FUNCTION_APP_SERVICE_PLAN_NAME}"
    "seedFunctionsStorageAccountName=${SEED_FUNCTIONS_STORAGE_ACCOUNT_NAME}"
    "tags=${TAGS_JSON}"
  )

  log_resolved_parameters

  if [[ "${DRY_RUN}" -eq 1 ]]; then
    local -a what_if_cmd=(
      deployment sub what-if
      --name "${DEPLOYMENT_NAME}"
      --location "${LOCATION}"
      --template-file "${TEMPLATE_FILE}"
      --parameters
      "nowYyyymmddHhmm=${DATE_SUFFIX}"
      "workloadCode=${WORKLOAD_CODE}"
      "deploymentEnvironment=${DEPLOYMENT_ENVIRONMENT}"
      "regionCode=${REGION_CODE}"
      "storageAccountName=${STORAGE_ACCOUNT_NAME}"
      "containerName=${CONTAINER_NAME}"
      "postgresServerName=${POSTGRES_SERVER_NAME}"
      "postgresAdminUser=${POSTGRES_ADMIN_USER}"
      "postgresAdminPassword=${POSTGRES_ADMIN_PASSWORD}"
      "postgresDatabaseName=${POSTGRES_DB_NAME}"
      "postgresEntraAdminObjectId=${POSTGRES_ENTRA_ADMIN_OBJECT_ID}"
      "postgresEntraAdminPrincipalName=${POSTGRES_ENTRA_ADMIN_NAME}"
      "postgresEntraAdminPrincipalType=${POSTGRES_ENTRA_ADMIN_TYPE}"
      "postgresVersion=${POSTGRES_VERSION}"
      "postgresTier=${POSTGRES_TIER}"
      "postgresSkuName=${POSTGRES_SKU_NAME}"
      "postgresStorageSizeGB=${POSTGRES_STORAGE_GB}"
      "containerAppsEnvironmentName=${CONTAINER_APPS_ENVIRONMENT_NAME}"
      "containerAppName=${CONTAINER_APP_NAME}"
      "virtualNetworkName=${VIRTUAL_NETWORK_NAME}"
      "appContainerImage=${APP_CONTAINER_IMAGE}"
      "memcachedContainerImage=${MEMCACHED_CONTAINER_IMAGE}"
      "functionAppName=${FUNCTION_APP_NAME}"
      "functionAppServicePlanName=${FUNCTION_APP_SERVICE_PLAN_NAME}"
      "functionsStorageAccountName=${FUNCTIONS_STORAGE_ACCOUNT_NAME}"
      "seedFunctionAppName=${SEED_FUNCTION_APP_NAME}"
      "seedFunctionAppServicePlanName=${SEED_FUNCTION_APP_SERVICE_PLAN_NAME}"
      "seedFunctionsStorageAccountName=${SEED_FUNCTIONS_STORAGE_ACCOUNT_NAME}"
      "tags=${TAGS_JSON}"
    )
    log "Running what-if (no changes applied)"
    run_az "${what_if_cmd[@]}"
    print_application_env
    print_apim_test_guide
    print_mcp_config
    print_seed_config
    return 0
  fi

  log "Deploying infra with name=${DEPLOYMENT_NAME}, location=${LOCATION}"
  run_az "${deploy_cmd[@]}"
  log "Deployment completed"
  print_application_env
  write_application_env_file

  if [[ "${RUN_STORAGE_ROLE_GRANT}" -eq 1 ]]; then
    if [[ -x "${ROOT_DIR}/script/grant-storage-role" ]]; then
      log "Granting Storage Blob Data Contributor role for current signed-in principal"
      "${ROOT_DIR}/script/grant-storage-role" --storage-account "${STORAGE_ACCOUNT_NAME}"
    else
      log "Warning: script/grant-storage-role not found or not executable. Run it manually."
    fi
  else
    log "Skipped storage role grant (--skip-storage-role-grant)"
  fi

  if [[ "${RUN_POSTGRES_MI_GRANT}" -eq 0 ]]; then
    log "Skipped PostgreSQL managed identity grant (--skip-postgres-mi-grant)"
  else
    log "Skipping script/grant-postgres-mi-role due to policy constraints"
  fi

  log "For local development, allow your client IP in both network firewalls before connecting:"
  log "1) Blob Storage (${STORAGE_ACCOUNT_NAME}) firewall/IP rules"
  log "2) PostgreSQL Flexible Server (${POSTGRES_SERVER_NAME}) firewall/IP rules"

  print_apim_test_guide
  print_mcp_config
  print_seed_config
}

main "$@"
