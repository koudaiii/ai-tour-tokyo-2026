# Database
# Uncomment to use a single URL. Leaving this commented lets script/bootstrap
# auto-create the local role/database via ISUCONP_DB_* defaults.
# ISUCONP_DATABASE_URL=postgresql://isuconp:isuconp@127.0.0.1:5432/isuconp

# Cache
ISUCONP_MEMCACHED_ADDRESS=127.0.0.1:11211

# Azure Blob Storage (optional)
# If both are unset, the app keeps using posts.imgdata.
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_ACCOUNT_URL=
AZURE_STORAGE_CONTAINER_NAME=images

# Azure API Management (set by script/deploy-infra)
APIM_NAME=
APIM_GATEWAY_URL=

# Azure Functions MCP Server (set by script/deploy-infra)
FUNCTION_APP_NAME=
FUNCTION_APP_MCP_ENDPOINT=

# Seed Function (set by script/deploy-infra)
SEED_FUNCTION_APP_NAME=
SEED_FUNCTION_APP_ENDPOINT=
SEED_FUNCTION_KEY=
